# ============================================================
# Production Environment Configuration Template
# ============================================================
# ⚠️  DO NOT commit this file with real values!
# Copy to .env.production and fill in via secrets manager

APP_NAME=pm-internship-engine
ENVIRONMENT=production
SECRET_KEY=${SECRET_KEY}
ALLOWED_ORIGINS=https://pm-internship.gov.in,https://admin.pm-internship.gov.in
LOG_LEVEL=warning

# Database (from AWS Secrets Manager)
DATABASE_URL=${DATABASE_URL}
POSTGRES_HOST=${POSTGRES_HOST}
POSTGRES_PORT=5432
POSTGRES_DB=pm_internship
POSTGRES_USER=pm_admin
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis (from AWS Secrets Manager)
REDIS_URL=${REDIS_URL}
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_DB=0
CACHE_TTL=3600

# OpenSearch (from AWS Secrets Manager)
OPENSEARCH_URL=${OPENSEARCH_URL}
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=${OPENSEARCH_PASSWORD}
OPENSEARCH_INDEX_PREFIX=pm_internship

# Temporal
TEMPORAL_ADDRESS=${TEMPORAL_ADDRESS}
TEMPORAL_NAMESPACE=production
TEMPORAL_TASK_QUEUE=pm-allocation
TEMPORAL_API_KEY=${TEMPORAL_API_KEY}

# Matching Algorithm
MATCHING_WEIGHT_SKILLS=0.30
MATCHING_WEIGHT_LOCATION=0.15
MATCHING_WEIGHT_SECTOR=0.20
MATCHING_WEIGHT_QUALIFICATIONS=0.15
MATCHING_WEIGHT_FAIRNESS=0.20
MATCH_MIN_THRESHOLD=0.4
MAX_CANDIDATES_PER_OPPORTUNITY=15
MAX_OPPORTUNITIES_PER_CANDIDATE=5

# Fairness
FAIRNESS_ENABLED=true
FAIRNESS_MIN_REPRESENTATION=0.30
FAIRNESS_GEO_DIVERSITY_TARGET=0.40
FAIRNESS_SES_BOOST=1.2

# Email (SES)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@pm-internship.gov.in
SMTP_TLS=true

# Frontend
NEXT_PUBLIC_API_URL=https://api.pm-internship.gov.in
NEXT_PUBLIC_WS_URL=wss://api.pm-internship.gov.in
NEXT_PUBLIC_APP_NAME=PM Internship Smart Allocation Engine

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
OTEL_EXPORTER_OTLP_ENDPOINT=${OTEL_ENDPOINT}
METRICS_PORT=9090

# AWS
AWS_REGION=ap-south-1
S3_BUCKET=${S3_BUCKET}

# Production flags
DEBUG=false
SQL_ECHO=false
SEED_ON_STARTUP=false
DISABLE_AUTH=false
