# ============================================================
# Environment Variables - PM Internship Smart Allocation Engine
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env files to version control

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Application name
APP_NAME=pm-internship-engine

# Environment: development | staging | production
ENVIRONMENT=development

# Secret key for JWT tokens and session signing (generate with: openssl rand -hex 64)
SECRET_KEY=change-me-in-production

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# Full connection URL
DATABASE_URL=postgresql+asyncpg://pm_admin:changeme@localhost:5432/pm_internship

# Individual connection parameters (used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pm_internship
POSTGRES_USER=pm_admin
POSTGRES_PASSWORD=changeme

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
# Full connection URL
REDIS_URL=redis://localhost:6379/0

# Individual connection parameters
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0

# Cache TTL in seconds
CACHE_TTL=3600

# ─────────────────────────────────────────────
# OpenSearch
# ─────────────────────────────────────────────
# OpenSearch endpoint URL
OPENSEARCH_URL=http://localhost:9200

# OpenSearch credentials
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Ch@ngeme1!

# Index prefix for all indices
OPENSEARCH_INDEX_PREFIX=pm_internship

# ─────────────────────────────────────────────
# Temporal (Workflow Orchestration)
# ─────────────────────────────────────────────
# Temporal server address
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace
TEMPORAL_NAMESPACE=default

# Temporal task queue for allocation workflows
TEMPORAL_TASK_QUEUE=pm-allocation

# Temporal API key (for Temporal Cloud)
TEMPORAL_API_KEY=

# ─────────────────────────────────────────────
# Matching Algorithm
# ─────────────────────────────────────────────
# Default weights for matching stages (must sum to 1.0)
MATCHING_WEIGHT_SKILLS=0.30
MATCHING_WEIGHT_LOCATION=0.15
MATCHING_WEIGHT_SECTOR=0.20
MATCHING_WEIGHT_QUALIFICATIONS=0.15
MATCHING_WEIGHT_FAIRNESS=0.20

# Minimum match score threshold (0.0 - 1.0)
MATCH_MIN_THRESHOLD=0.3

# Maximum candidates per opportunity
MAX_CANDIDATES_PER_OPPORTUNITY=10

# Maximum opportunities per candidate
MAX_OPPORTUNITIES_PER_CANDIDATE=5

# ─────────────────────────────────────────────
# Fairness Policy
# ─────────────────────────────────────────────
# Enable fairness-aware allocation
FAIRNESS_ENABLED=true

# Minimum percentage of allocations for underrepresented groups
FAIRNESS_MIN_REPRESENTATION=0.30

# Geographic diversity target
FAIRNESS_GEO_DIVERSITY_TARGET=0.40

# Socioeconomic priority boost factor (1.0 = no boost)
FAIRNESS_SES_BOOST=1.2

# ─────────────────────────────────────────────
# Email / Notifications
# ─────────────────────────────────────────────
# SMTP settings
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pm-internship.local
SMTP_TLS=false

# ─────────────────────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────────────────────
# Public-facing API URL (accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Application title
NEXT_PUBLIC_APP_NAME=PM Internship Smart Allocation Engine

# ─────────────────────────────────────────────
# Monitoring & Observability
# ─────────────────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Prometheus metrics port
METRICS_PORT=9090

# ─────────────────────────────────────────────
# AWS (Production)
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for file uploads
S3_BUCKET=

# ─────────────────────────────────────────────
# Development Only
# ─────────────────────────────────────────────
# Enable debug mode
DEBUG=false

# Enable SQL query logging
SQL_ECHO=false

# Seed data on startup
SEED_ON_STARTUP=false

# Disable authentication (development only!)
DISABLE_AUTH=false
